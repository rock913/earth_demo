# Optional env vars for AlphaEarth service
# Copy to: /etc/alphaearth/alphaearth.env

# v5 cache path (recommended)
# GEE_USER_PATH="users/<your_gee_username>/aef_demo"

# Interactive auth (earthengine authenticate) uses local user credentials and needs no env.

# If you later switch to service account auth, uncomment and set:
# EE_SERVICE_ACCOUNT="xxx@yyy.iam.gserviceaccount.com"
# EE_PRIVATE_KEY_FILE="/etc/alphaearth/service-account-key.json"

# Streamlit bind (normally overridden by systemd service)
# HOST=127.0.0.1
# PORT=8501
